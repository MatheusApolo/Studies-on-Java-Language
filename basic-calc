import java.util.Scanner;
public class Teste {
    public static void main(String[] args) {

        Scanner scan = new Scanner(System.in);

        double a;
        double b;
        String operador;

        System.out.print("Digite o primeiro número: ");

        a = scan.nextDouble();

        System.out.print("Digite o segundo número: ");

        b = scan.nextDouble();

        scan.nextLine();

        System.out.print("Digite o operador a ser utilizado: ");

        operador = scan.nextLine();

        switch (operador) {
            case "+":
                System.out.print("Resultado da soma: " + (a + b));
                break;
            case "-":
                System.out.print("Resultado da subtração: " + (a - b));
                break;
            case "*":
                System.out.print("Resultado da multiplicação: " + (a * b));
                break;
            case "/":
                if(b != 0) {
                System.out.print("Resultado da divisão: " + (a / b));
                } else {
                    System.out.println("Divisão inválida");
                }
                break;
            default:
                System.out.println("Operador inválido");
        }

            scan.close();
    }
}
