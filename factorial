public class Teste {
    public static int calcularFatorial(int n){

        int fatorial = 1;

        for (int i = 1; i <= n; i++) {

            fatorial *= i;

        }
        return fatorial;
    }

    public static void main(String[] args) {

        System.out.println("Fatorial: " + (calcularFatorial(6)));

    }
}
