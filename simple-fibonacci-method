import java.util.Scanner;

public class Teste {
    public static int fibonacci(int n) {
        
        if (n <= 1) {
            return 0;
        }

        if (n == 2) {
            return 1;
        }

        int anterior = 0;
        int atual = 1;
        int proximo;

        for (int i = 3; i <= n; i++) {

            proximo = anterior + atual;
            anterior = atual;
            atual = proximo;

        } return atual;
    }

public static void main(String[] args) {

    Scanner scanner = new Scanner(System.in);

        System.out.print("Digite a posição que deseja buscar: ");

        int result = fibonacci(scanner.nextInt());

        System.out.print("Resultado da busca: " + result);

    scanner.close();

    }
}
