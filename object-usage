public class Main {
    public static void main(String[] args) {

        Produto p1 = new Produto();

        p1.nomeProduto = "Sabonete";
        p1.preco = 6.25;
        p1.quantidadeEstoque = 150;
        p1.estaDisponivel = true;

    System.out.println("Produto: " + p1.nomeProduto);
    System.out.println("Preço: R$ " + p1.preco);
    System.out.println("Quantidade no estoque: " + p1.quantidadeEstoque);
    System.out.println("Esta disponível: " + p1.estaDisponivel);
    System.out.println("Valor do Estoque: R$ " + p1.quantidadeEstoque * p1.preco);
    }

    static class Produto {
        String nomeProduto;
        double preco;
        int quantidadeEstoque;
        boolean estaDisponivel;

    }
}
